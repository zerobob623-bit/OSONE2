rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isValidMessage(data) {
      return data.role in ['user', 'model'] &&
             data.text is string && data.text.size() <= 5000 &&
             data.createdAt is timestamp &&
             data.userId is string &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 10000));
    }

    function isValidMemory(data) {
      return (!('userName' in data) || (data.userName is string && data.userName.size() <= 100)) &&
             (!('facts' in data) || (data.facts is list && data.facts.size() <= 100)) &&
             (!('preferences' in data) || (data.preferences is list && data.preferences.size() <= 100)) &&
             (!('importantDates' in data) || (data.importantDates is list && data.importantDates.size() <= 50)) &&
             (!('workspace' in data) || (data.workspace is string && data.workspace.size() <= 50000)) &&
             (!('semanticMemory' in data) || (data.semanticMemory is list && data.semanticMemory.size() <= 200)) &&
             (!('summaries' in data) || (data.summaries is list && data.summaries.size() <= 100));
    }

    function isValidDiaryEntry(data) {
      return data.content is string && data.content.size() <= 10000 &&
             data.mood is string && data.mood.size() <= 50 &&
             data.createdAt is timestamp &&
             data.userId is string;
    }

    match /users/{userId} {
      allow read, write: if true;

      match /messages/{messageId} {
        allow read: if true;
        allow create: if isValidMessage(request.resource.data) && request.resource.data.userId == userId;
        allow delete: if true;
        allow update: if false;
      }

      match /memory/main {
        allow read: if true;
        allow write: if isValidMemory(request.resource.data);
      }

      match /diary/{entryId} {
        allow read: if true;
        allow create: if isValidDiaryEntry(request.resource.data) && request.resource.data.userId == userId;
        allow delete: if true;
        allow update: if false;
      }
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
